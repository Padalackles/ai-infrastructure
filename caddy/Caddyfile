# ──────────────────────────────────────────
# Caddyfile — Reverse Proxy + Auto HTTPS
# ──────────────────────────────────────────
# Caddy automatically provisions Let's Encrypt
# certificates and redirects HTTP → HTTPS.

{
    email {$CADDY_ACME_EMAIL}
}

{$DOMAIN:localhost} {
    # Reverse proxy /mcp to the Hub
    reverse_proxy /mcp* mcp-hub:8080

    # Health check endpoint
    reverse_proxy /health* mcp-hub:8080
    reverse_proxy /status* mcp-hub:8080
    reverse_proxy /tools* mcp-hub:8080

    # Default: proxy everything to Hub
    reverse_proxy mcp-hub:8080
}
