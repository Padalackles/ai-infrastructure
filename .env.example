# ──────────────────────────────────────────
# MCP Hub — Environment Variables
# ──────────────────────────────────────────
# Copy to .env and fill in your values.

# ── Domain ─────────────────────────────────
DOMAIN=raven-victor.click
MCP_HUB_PORT=8080

# ── Caddy (Let's Encrypt) ──────────────────
CADDY_ACME_EMAIL=admin@raven-victor.click

# ── Auth (Bearer Token) ────────────────────
# Generates: openssl rand -hex 32
# Leave empty to disable (local dev only — always set in production)
MCP_HUB_AUTH_TOKEN=your-secret-token-here

# ── Cloudflare ─────────────────────────────
CF_API_TOKEN=your-cloudflare-api-token
CF_ZONE_ID=your-cloudflare-zone-id
CF_TUNNEL_NAME=mcp-hub-tunnel

# ── Ombre (external deployment) ────────────
OMBRE_URL=http://45.76.169.98:8000/mcp

# ── ntfy (external service) ────────────────
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=raven-victor-c503460d
